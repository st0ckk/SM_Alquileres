<!DOCTYPE html>
@using Microsoft.AspNetCore.Http
<html lang="es">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <title>Sistema de Gestión de Alquileres - @ViewData["Title"]</title>

    <!-- Bootstrap core CSS -->
    <link href="~/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">

    <!-- Additional CSS Files -->
    <link rel="stylesheet" href="~/css/fontawesome.css">
    <link rel="stylesheet" href="~/css/templatemo-villa-agency.css">
    <link rel="stylesheet" href="~/css/owl.css">
    <link rel="stylesheet" href="~/css/animate.css">
    <link rel="stylesheet" href="~/css/sga-overrides.css" asp-append-version="true">
</head>

<body>
    @{
        var usuarioEmail = Context.Session.GetString("UsuarioEmail");
        var usuarioNombre = Context.Session.GetString("UsuarioNombre");
        var usuarioRol = Context.Session.GetString("UsuarioRol");
    }
    <!-- ***** Preloader Start ***** -->
    <div id="js-preloader" class="js-preloader">
        <div class="preloader-inner">
            <span class="dot"></span>
            <div class="dots">
                <span></span>
                <span></span>
                <span></span>
            </div>
        </div>
    </div>
    <!-- ***** Preloader End ***** -->

    <div class="sub-header">
        <div class="container">
            <div class="row">
                <div class="col-lg-8 col-md-8">
                    <ul class="info">
                        <li><i class="fa fa-envelope"></i> info@alquileres.com</li>
                        <li><i class="fa fa-map"></i> San José, Costa Rica</li>
                    </ul>
                </div>
                <div class="col-lg-4 col-md-4">
                    <ul class="social-links">
                        <li><a href="#"><i class="fab fa-facebook"></i></a></li>
                        <li><a href="#"><i class="fab fa-twitter"></i></a></li>
                        <li><a href="#"><i class="fab fa-linkedin"></i></a></li>
                        <li><a href="#"><i class="fab fa-instagram"></i></a></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- ***** Header Area Start ***** -->
    <header class="header-area header-sticky">
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <nav class="main-nav">
                        <!-- ***** Logo Start ***** -->
                        <a asp-controller="Home" asp-action="Index" class="logo">
                            <h1>Alquileres</h1>
                        </a>
                        <!-- ***** Logo End ***** -->
                        <!-- ***** Menu Start ***** -->
                        <ul class="nav">
                            <li><a asp-controller="Home" asp-action="Index" class="active">Inicio</a></li>
                            <li><a asp-controller="Home" asp-action="Index" asp-route-pagina="1" asp-fragment="propiedades">Propiedades</a></li>
                            <li><a asp-controller="Home" asp-action="Index" asp-fragment="contacto">Contacto</a></li>
                            @if (string.IsNullOrWhiteSpace(usuarioEmail))
                            {
                                <li><a asp-controller="Home" asp-action="Registro">Registro</a></li>
                            }
                            @if ((usuarioRol ?? string.Empty).ToUpperInvariant() == "ADMINISTRADOR")
                            {
                                <li><a asp-controller="Admin" asp-action="Index">Panel Admin</a></li>
                            }
                            else if (!string.IsNullOrWhiteSpace(usuarioEmail))
                            {
                                <li><a asp-controller="Cliente" asp-action="Notificaciones">Notificaciones</a></li>
                                <li><a asp-controller="Cliente" asp-action="Mensajes">Mensajes</a></li>
                            }
                            @if (string.IsNullOrWhiteSpace(usuarioEmail))
                            {
                                <li><a asp-controller="Home" asp-action="Login"><i class="fa fa-user"></i> Iniciar Sesión</a></li>
                            }
                            else
                            {
                                <li class="sga-user-menu">
                                    <div class="sga-user-wrap">
                                        <a href="#" class="sga-user-toggle">
                                            <i class="fa fa-user"></i>
                                            @(string.IsNullOrWhiteSpace(usuarioNombre) ? usuarioEmail : usuarioNombre)
                                        </a>
                                        <ul class="sga-user-dropdown">
                                            <li><a asp-controller="Home" asp-action="CambiarContrasenna">Cambiar Contraseña</a></li>
                                            <li class="sga-nav-row">
                                                <form asp-controller="Home" asp-action="Logout" method="post" class="sga-inline-form">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="sga-link-button">
                                                        Cerrar Sesión
                                                    </button>
                                                </form>
                                            </li>
                                        </ul>
                                    </div>
                                </li>
                            }
                        </ul>
                        <a class='menu-trigger'>
                            <span>Menu</span>
                        </a>
                        <!-- ***** Menu End ***** -->
                    </nav>
                </div>
            </div>
        </div>
    </header>
    <!-- ***** Header Area End ***** -->

    @RenderBody()

    <footer>
        <div class="container">
            <div class="col-lg-8">
                <p>Copyright © 2024 Sistema de Gestión de Alquileres. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/vendor/jquery/jquery.min.js"></script>
    <script src="~/vendor/bootstrap/js/bootstrap.min.js"></script>
    <script src="~/js/isotope.min.js"></script>
    <script src="~/js/owl-carousel.js"></script>
    <script src="~/js/counter.js"></script>
    <script src="~/js/custom.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
