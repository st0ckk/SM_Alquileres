@model SGA_WEB.Models.ClienteNotificacionesViewModel
@{
    ViewData["Title"] = "Mis Notificaciones";
    Layout = "_Layout";
}

<div class="properties section" style="padding-top: 140px;">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="section-heading mb-4">
                    <h6>| Cliente</h6>
                    <h2>Estado de Sus Citas</h2>
                </div>
                <div class="table-responsive" style="background:#fff;border-radius:10px;padding:15px;">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Propiedad</th>
                                <th>Fecha Visita</th>
                                <th>Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model.Citas)
                            {
                                var css = c.Estado switch
                                {
                                    "APROBADA" => "badge bg-success",
                                    "CANCELADA" => "badge bg-danger",
                                    _ => "badge bg-warning text-dark"
                                };
                                <tr>
                                    <td>@c.PropiedadInteres</td>
                                    <td>@c.FechaVisita.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td><span class="@css">@c.Estado</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    @if (!Model.Citas.Any())
                    {
                        <p class="mb-0">No tiene citas registradas por el momento.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
