@model SGA_WEB.Models.CambiarContrasennaInputModel
@{
    ViewData["Title"] = "Cambiar Contraseña";
    Layout = "_Layout";
}

<div class="featured section sga-page-top">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="section-heading">
                    <h6>| Seguridad</h6>
                    <h2>Cambiar Contraseña</h2>
                </div>

                @if (ViewBag.Error is not null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }
                @if (TempData["Success"] is not null)
                {
                    <div class="alert alert-success">@TempData["Success"]</div>
                }

                <form asp-controller="Home" asp-action="CambiarContrasenna" method="post" class="p-4 sga-card-surface">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label asp-for="ContrasennaActual" class="form-label"></label>
                        <input asp-for="ContrasennaActual" type="password" class="form-control" />
                        <span asp-validation-for="ContrasennaActual" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NuevaContrasenna" class="form-label"></label>
                        <input asp-for="NuevaContrasenna" type="password" class="form-control" />
                        <span asp-validation-for="NuevaContrasenna" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ConfirmarNuevaContrasenna" class="form-label"></label>
                        <input asp-for="ConfirmarNuevaContrasenna" type="password" class="form-control" />
                        <span asp-validation-for="ConfirmarNuevaContrasenna" class="text-danger"></span>
                    </div>
                    <button type="submit" class="btn btn-primary">Actualizar contraseña</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
