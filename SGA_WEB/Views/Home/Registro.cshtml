@model Usuario
@inject IConfiguration Configuration
@{
    ViewData["Title"] = "Registro de Usuario";
    Layout = "_LayoutExterno";
}

<div class="main-banner">
    <div class="owl-carousel owl-banner">
        <div class="item item-1">
            <div class="header-text">
                <span class="category">Únete a Nosotros, <em>Hoy</em></span>
                <h2>Regístrate<br>Crea Tu Cuenta Ahora</h2>
            </div>
        </div>
        <div class="item item-2">
            <div class="header-text">
                <span class="category">Comienza Ya, <em>Tu Aventura</em></span>
                <h2>Forma Parte<br>De Nuestra Comunidad</h2>
            </div>
        </div>
        <div class="item item-3">
            <div class="header-text">
                <span class="category">Sistema Completo, <em>Alquileres</em></span>
                <h2>¡Regístrate!<br>Accede a Todas las Funciones</h2>
            </div>
        </div>
    </div>
</div>

<div class="featured section">
    <div class="container">
        <div class="row">
            <div class="col-lg-4">
                <div class="left-image">
                    <img src="~/images/featured.jpg" alt="">
                </div>
            </div>
            <div class="col-lg-8">
                <div class="section-heading">
                    <h6>| Registro de Usuario</h6>
                    <h2>Completa Tus Datos Personales</h2>
                </div>

                <form asp-controller="Home" asp-action="Registro" class="custom-form contact-form" role="form" style="background: rgba(255, 255, 255, 0.95); padding: 40px; border-radius: 10px; margin-top: 20px;">
                    @Html.AntiForgeryToken()
                    <div class="row">
                        <div class="col-lg-6 col-12">
                            <div class="form-floating">
                                <input type="text" asp-for="Nombre" class="form-control" placeholder="Nombre" required="">
                                <label for="floatingInput">Nombre</label>
                            </div>
                        </div>

                        <div class="col-lg-6 col-12">
                            <div class="form-floating">
                                <input type="text" asp-for="Apellidos" class="form-control" placeholder="Apellidos" required="">
                                <label for="floatingInput">Apellidos</label>
                            </div>
                        </div>

                        <div class="col-lg-6 col-12">
                            <div class="form-floating">
                                <input type="email" asp-for="Email" class="form-control" placeholder="Correo Electrónico" required="">
                                <label for="floatingInput">Correo Electrónico</label>
                            </div>
                        </div>

                        <div class="col-lg-6 col-12">
                            <div class="form-floating">
                                <input type="tel" asp-for="Telefono" class="form-control" placeholder="Teléfono" required="">
                                <label for="floatingInput">Teléfono</label>
                            </div>
                        </div>

                        <div class="col-lg-6 col-12">
                            <div class="form-floating">
                                <input type="date" asp-for="FechaNacimiento" class="form-control" placeholder="Fecha de Nacimiento">
                                <label for="floatingInput">Fecha de Nacimiento</label>
                            </div>
                        </div>

                        <div class="col-lg-6 col-12">
                            <div class="form-floating">
                                <input type="text" asp-for="Direccion" class="form-control" placeholder="Dirección">
                                <label for="floatingInput">¿Dónde Vive? (Dirección)</label>
                            </div>
                        </div>

                        <div class="col-lg-6 col-12">
                            <div class="form-floating">
                                <input type="text" asp-for="Identificacion" id="cedula-input" maxlength="11" class="form-control" placeholder="Cédula (x-xxxx-xxxx)" pattern="^\d-\d{4}-\d{4}$" title="Formato requerido: x-xxxx-xxxx" required="">
                                <label for="floatingInput">Identificación</label>
                            </div>
                            <small id="cedula-feedback" style="display:block;margin-top:6px;color:#666;"></small>
                        </div>

                        <div class="col-lg-6 col-12">
                            <div class="form-floating">
                                <input type="password" asp-for="Contrasenna" class="form-control" placeholder="Contraseña" required="">
                                <label for="floatingInput">Contraseña</label>
                            </div>
                        </div>

                        @if (ViewBag.Error != null)
                        {
                            <div class="col-lg-12 col-12">
                                <div class="alert alert-danger" role="alert">
                                    @ViewBag.Error
                                </div>
                            </div>
                        }

                        @if (ViewBag.Success != null)
                        {
                            <div class="col-lg-12 col-12">
                                <div class="alert alert-success" role="alert">
                                    @ViewBag.Success
                                </div>
                            </div>
                        }

                        <div class="col-lg-12 col-12">
                            <button type="submit" class="form-control" style="background: #f35525; color: white; border: none; padding: 15px; border-radius: 5px; font-weight: 600; margin-top: 10px;">Registrarse</button>
                        </div>

                        <div class="col-12 text-center mt-4">
                            <a asp-controller="Home" asp-action="Login" class="btn custom-btn custom-border-btn ms-3" style="color: #333;">¿Ya tiene una cuenta? Iniciar Sesión</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const apiBaseUrl = '@(Configuration["ApiSettings:BaseUrl"] ?? "http://localhost:5277")';
            const input = document.getElementById('cedula-input');
            const nombreInput = document.getElementById('Nombre');
            const apellidosInput = document.getElementById('Apellidos');
            const feedback = document.getElementById('cedula-feedback');
            if (!input) return;

            input.addEventListener('input', function () {
                const digits = (this.value || '').replace(/\D/g, '').substring(0, 9);
                let formatted = digits;

                if (digits.length > 1) {
                    formatted = digits.substring(0, 1) + '-' + digits.substring(1);
                }
                if (digits.length > 5) {
                    formatted = formatted.substring(0, 6) + '-' + digits.substring(5);
                }

                this.value = formatted;

                if (formatted.length === 11) {
                    fetch(`${apiBaseUrl}/api/personas/cedula/${encodeURIComponent(formatted)}`)
                        .then(response => response.ok ? response.json() : null)
                        .then(data => {
                            if (!data) {
                                if (feedback) {
                                    feedback.textContent = 'No se encontraron datos para esta cédula.';
                                    feedback.style.color = '#b02a37';
                                }
                                return;
                            }
                            if (nombreInput && data.nombre) {
                                nombreInput.value = data.nombre;
                            }
                            if (apellidosInput && data.apellidos) {
                                apellidosInput.value = data.apellidos;
                            }
                            if (feedback) {
                                feedback.textContent = 'Datos encontrados y autocompletados.';
                                feedback.style.color = '#146c43';
                            }
                        })
                        .catch(() => {
                            if (feedback) {
                                feedback.textContent = 'No fue posible consultar la API de cédula.';
                                feedback.style.color = '#b02a37';
                            }
                        });
                } else if (feedback) {
                    feedback.textContent = '';
                }
            });
        })();
    </script>
}

<div class="fun-facts">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="wrapper">
                    <div class="row">
                        <div class="col-lg-4">
                            <div class="counter">
                                <h2 class="timer count-title count-number" data-to='150' data-speed='1000'></h2>
                                <p class="count-text">Propiedades<br>Disponibles</p>
                            </div>
                        </div>
                        <div class="col-lg-4">
                            <div class="counter">
                                <h2 class="timer count-title count-number" data-to='10' data-speed='1000'></h2>
                                <p class="count-text">Años<br>de Experiencia</p>
                            </div>
                        </div>
                        <div class="col-lg-4">
                            <div class="counter">
                                <h2 class="timer count-title count-number" data-to='500' data-speed='1000'></h2>
                                <p class="count-text">Clientes<br>Satisfechos</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
