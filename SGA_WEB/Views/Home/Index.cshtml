@model SGA_WEB.Models.HomeIndexViewModel
@using System.Globalization
@{
    ViewData["Title"] = "Inicio";
    Layout = "_Layout";
    var propiedadSeleccionada = Model.PropiedadSeleccionadaQuery;
    var esCr = CultureInfo.GetCultureInfo("es-CR");
    string UrlImagenPropiedad(SGA.Infrastructure.Services.PropiedadListaItem p)
    {
        if (string.IsNullOrWhiteSpace(p.UrlFoto))
            return Url.Content("~/images/property-02.jpg");
        var u = p.UrlFoto!.Trim();
        return u.StartsWith("~/", StringComparison.Ordinal) ? Url.Content(u) : Url.Content("~" + u);
    }
}

<div class="main-banner">
    <div class="owl-carousel owl-banner">
        <div class="item item-1">
            <div class="header-text">
                <span class="category">San José, <em>Costa Rica</em></span>
                <h2>¡Encuentra!<br>La mejor propiedad para alquilar</h2>
            </div>
        </div>
        <div class="item item-2">
            <div class="header-text">
                <span class="category">Alajuela, <em>Costa Rica</em></span>
                <h2>¡Rápido!<br>Encuentra la mejor propiedad en la ciudad</h2>
            </div>
        </div>
        <div class="item item-3">
            <div class="header-text">
                <span class="category">Cartago, <em>Costa Rica</em></span>
                <h2>¡Actúa ahora!<br>Encuentra tu hogar ideal</h2>
            </div>
        </div>
    </div>
</div>

<div class="featured section">
    <div class="container">
        <div class="row">
            <div class="col-lg-4">
                <div class="left-image">
                    <img src="~/images/featured.jpg" alt="">
                    <a href="#propiedades"><img src="~/images/featured-icon.png" alt="" class="sga-featured-icon"></a>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="section-heading">
                    <h6>| Destacado</h6>
                    <h2>Mejor Apartamento & Vista al Mar</h2>
                </div>
                <div class="accordion" id="accordionExample">
                    <div class="accordion-item">
                        <h2 class="accordion-header" id="headingOne">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
                                ¿Cómo funciona el sistema?
                            </button>
                        </h2>
                        <div id="collapseOne" class="accordion-collapse collapse show" aria-labelledby="headingOne" data-bs-parent="#accordionExample">
                            <div class="accordion-body">
                                Nuestro <strong>sistema de gestión de alquileres</strong> te permite buscar, visualizar y gestionar propiedades disponibles para alquiler. Regístrate como usuario para acceder a todas las funcionalidades.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h2 class="accordion-header" id="headingTwo">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">
                                ¿Qué tipos de propiedades ofrecemos?
                            </button>
                        </h2>
                        <div id="collapseTwo" class="accordion-collapse collapse" aria-labelledby="headingTwo" data-bs-parent="#accordionExample">
                            <div class="accordion-body">
                                Ofrecemos una amplia variedad de propiedades: <strong>casas, apartamentos, villas y condominios</strong> en diferentes zonas del país. Todas nuestras propiedades están verificadas y listas para alquilar.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h2 class="accordion-header" id="headingThree">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseThree" aria-expanded="false" aria-controls="collapseThree">
                                ¿Por qué elegir nuestro sistema?
                            </button>
                        </h2>
                        <div id="collapseThree" class="accordion-collapse collapse" aria-labelledby="headingThree" data-bs-parent="#accordionExample">
                            <div class="accordion-body">
                                Ofrecemos un <strong>sistema confiable y fácil de usar</strong> para gestionar tus alquileres. Con nuestro sistema puedes buscar propiedades, contactar propietarios y gestionar tus contratos de manera eficiente.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-3">
                <div class="info-table">
                    <ul>
                        <li>
                            <img src="~/images/info-icon-01.png" alt="" class="sga-info-icon">
                            <h4>250 m2<br><span>Espacio Total</span></h4>
                        </li>
                        <li>
                            <img src="~/images/info-icon-02.png" alt="" class="sga-info-icon">
                            <h4>Contrato<br><span>Listo para Firmar</span></h4>
                        </li>
                        <li>
                            <img src="~/images/info-icon-03.png" alt="" class="sga-info-icon">
                            <h4>Pago<br><span>Proceso de Pago</span></h4>
                        </li>
                        <li>
                            <img src="~/images/info-icon-04.png" alt="" class="sga-info-icon">
                            <h4>Seguridad<br><span>24/7 Bajo Control</span></h4>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="fun-facts">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="wrapper">
                    <div class="row">
                        <div class="col-lg-4">
                            <div class="counter">
                                <h2 class="timer count-title count-number" data-to='150' data-speed='1000'></h2>
                                <p class="count-text">Propiedades<br>Disponibles</p>
                            </div>
                        </div>
                        <div class="col-lg-4">
                            <div class="counter">
                                <h2 class="timer count-title count-number" data-to='10' data-speed='1000'></h2>
                                <p class="count-text">Años<br>de Experiencia</p>
                            </div>
                        </div>
                        <div class="col-lg-4">
                            <div class="counter">
                                <h2 class="timer count-title count-number" data-to='500' data-speed='1000'></h2>
                                <p class="count-text">Clientes<br>Satisfechos</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="section properties section" id="propiedades">
    <div class="container">
        <div class="row">
            <div class="col-12 text-center section-heading">
                <h2>Catálogo publicado</h2>
            </div>
        </div>
        @if (Model.TotalRegistros == 0)
        {
            <p class="text-center text-muted py-5 mb-0">Aún no hay propiedades.</p>
        }
        else
        {
        <div class="row">
            @foreach (var p in Model.Propiedades)
            {
                <div class="col-lg-6 col-md-6 mb-4">
                    <div class="item h-100 sga-prop-card">
                        <a href="#agendar-cita"><img src="@UrlImagenPropiedad(p)" alt=""></a>
                        <span class="category">@p.Tipo</span>
                        <h6>$@p.PrecioMensual.ToString("N2", esCr) / mes</h6>
                        <h4><a href="#propiedades">@p.Ubicacion</a></h4>
                        <ul class="mb-3">
                            <li>Habitaciones: <span>@p.NumeroHabitaciones</span></li>
                            <li>Área: <span>@p.EspacioTotalM2 m²</span></li>
                            <li>Piso: <span>@p.NumeroPiso</span></li>
                            <li>Estacionamiento: <span>@(p.EstacionamientoDisponible ? "Sí" : "No")</span></li>
                            <li>Pago: <span>@p.ProcesoPago</span></li>
                        </ul>
                        <p class="text-muted small mb-3" style="min-height: 3rem;">@p.Descripcion</p>
                        <div class="main-button">
                            <a asp-controller="Home" asp-action="Index" asp-route-pagina="@Model.PaginaActual" asp-fragment="agendar-cita" asp-route-propiedad="@p.TextoPropiedadInteres" asp-route-idPropiedad="@p.IdPropiedad">Agendar una visita</a>
                        </div>
                    </div>
                </div>
            }
        </div>
        @if (Model.TotalPaginas > 1)
        {
            var radio = 4;
            var ini = Math.Max(1, Model.PaginaActual - radio);
            var fin = Math.Min(Model.TotalPaginas, Model.PaginaActual + radio);
            <nav class="sga-pager d-flex flex-wrap justify-content-center align-items-center gap-2 mt-4 pt-3 border-top" aria-label="Paginación de propiedades">
                <span class="text-muted small me-2">Página @Model.PaginaActual de @Model.TotalPaginas</span>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(Model.PaginaActual <= 1 ? "disabled" : "")">
                        <a class="page-link" asp-controller="Home" asp-action="Index" asp-route-pagina="@(Model.PaginaActual - 1)" asp-route-propiedad="@(string.IsNullOrWhiteSpace(Model.PropiedadSeleccionadaQuery) ? null : Model.PropiedadSeleccionadaQuery)" asp-route-idPropiedad="@Model.IdPropiedadParaCita" asp-fragment="propiedades">Anterior</a>
                    </li>
                    @if (ini > 1)
                    {
                        <li class="page-item"><a class="page-link" asp-controller="Home" asp-action="Index" asp-route-pagina="1" asp-route-propiedad="@(string.IsNullOrWhiteSpace(Model.PropiedadSeleccionadaQuery) ? null : Model.PropiedadSeleccionadaQuery)" asp-route-idPropiedad="@Model.IdPropiedadParaCita" asp-fragment="propiedades">1</a></li>
                        <li class="page-item disabled"><span class="page-link">…</span></li>
                    }
                    @for (var i = ini; i <= fin; i++)
                    {
                        <li class="page-item @(i == Model.PaginaActual ? "active" : "")">
                            <a class="page-link" asp-controller="Home" asp-action="Index" asp-route-pagina="@i" asp-route-propiedad="@(string.IsNullOrWhiteSpace(Model.PropiedadSeleccionadaQuery) ? null : Model.PropiedadSeleccionadaQuery)" asp-route-idPropiedad="@Model.IdPropiedadParaCita" asp-fragment="propiedades">@i</a>
                        </li>
                    }
                    @if (fin < Model.TotalPaginas)
                    {
                        <li class="page-item disabled"><span class="page-link">…</span></li>
                        <li class="page-item"><a class="page-link" asp-controller="Home" asp-action="Index" asp-route-pagina="@Model.TotalPaginas" asp-route-propiedad="@(string.IsNullOrWhiteSpace(Model.PropiedadSeleccionadaQuery) ? null : Model.PropiedadSeleccionadaQuery)" asp-route-idPropiedad="@Model.IdPropiedadParaCita" asp-fragment="propiedades">@Model.TotalPaginas</a></li>
                    }
                    <li class="page-item @(Model.PaginaActual >= Model.TotalPaginas ? "disabled" : "")">
                        <a class="page-link" asp-controller="Home" asp-action="Index" asp-route-pagina="@(Model.PaginaActual + 1)" asp-route-propiedad="@(string.IsNullOrWhiteSpace(Model.PropiedadSeleccionadaQuery) ? null : Model.PropiedadSeleccionadaQuery)" asp-route-idPropiedad="@Model.IdPropiedadParaCita" asp-fragment="propiedades">Siguiente</a>
                    </li>
                </ul>
            </nav>
        }
        }
    </div>
</div>

<div class="contact section" id="contacto">
    <div class="container">
        <div class="row">
            <div class="col-lg-4 offset-lg-4">
                <div class="section-heading text-center">
                    <h6>| Contáctenos</h6>
                    <h2>Póngase en Contacto Con Nuestros Agentes</h2>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="contact-content">
    <div class="container">
        <div class="row">
            <div class="col-lg-7">
                <div id="map">
                    <iframe class="sga-map-embed" src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3929.982106088885!2d-84.07341768459224!3d9.92887639290538!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8fa0e3c5e3e5e3e5%3A0x8fa0e3c5e3e5e3e5!2sSan%20Jos%C3%A9%2C%20Costa%20Rica!5e0!3m2!1ses!2scr!4v1234567890123!5m2!1ses!2scr" width="100%" height="500px" frameborder="0" allowfullscreen=""></iframe>
                </div>
                <div class="row">
                    <div class="col-lg-6">
                        <div class="item phone">
                            <img src="~/images/phone-icon.png" alt="" class="sga-info-icon">
                            <h6>2222-0000<br><span>Número de Teléfono</span></h6>
                        </div>
                    </div>
                    <div class="col-lg-6">
                        <div class="item email">
                            <img src="~/images/email-icon.png" alt="" class="sga-info-icon">
                            <h6>info@alquileres.com<br><span>Email de Negocio</span></h6>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-5">
                @if (TempData["ContactSuccess"] is not null)
                {
                    <div class="alert alert-success">@TempData["ContactSuccess"]</div>
                }
                @if (TempData["ContactError"] is not null)
                {
                    <div class="alert alert-danger">@TempData["ContactError"]</div>
                }
                <form id="contact-form" asp-controller="Home" asp-action="GuardarMensaje" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row">
                        <div class="col-lg-12">
                            <fieldset>
                                <label for="name">Nombre Completo</label>
                                <input type="text" name="NombreCompleto" id="name" placeholder="Su Nombre..." autocomplete="on" required>
                            </fieldset>
                        </div>
                        <div class="col-lg-12">
                            <fieldset>
                                <label for="email">Dirección de Email</label>
                                <input type="email" name="Email" id="email" placeholder="Su E-mail..." required>
                            </fieldset>
                        </div>
                        <div class="col-lg-12">
                            <fieldset>
                                <label for="subject">Asunto</label>
                                <input type="text" name="Asunto" id="subject" placeholder="Asunto..." autocomplete="on" required>
                            </fieldset>
                        </div>
                        <div class="col-lg-12">
                            <fieldset>
                                <label for="message">Mensaje</label>
                                <textarea name="Mensaje" id="message" placeholder="Su Mensaje" required></textarea>
                            </fieldset>
                        </div>
                        <div class="col-lg-12">
                            <fieldset>
                                <button type="submit" id="form-submit" class="orange-button">Enviar Mensaje</button>
                            </fieldset>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="contact section" id="agendar-cita">
    <div class="container">
        <div class="row">
            <div class="col-lg-4 offset-lg-4">
                <div class="section-heading text-center">
                    <h6>| Citas</h6>
                    <h2>Agende Su Cita de Visita</h2>
                </div>
            </div>
        </div>
        <div class="row justify-content-center">
            <div class="col-lg-8">
                @if (TempData["CitaSuccess"] is not null)
                {
                    <div class="alert alert-success">@TempData["CitaSuccess"]</div>
                }
                @if (TempData["CitaError"] is not null)
                {
                    <div class="alert alert-danger">@TempData["CitaError"]</div>
                }
                @if (TempData["CitaWarning"] is not null)
                {
                    <div class="alert alert-warning">@TempData["CitaWarning"]</div>
                }
                <form asp-controller="Home" asp-action="AgendarCita" method="post" class="sga-visit-card">
                    @Html.AntiForgeryToken()
                    <div class="row">
                        <div class="col-lg-6">
                            <fieldset>
                                <label>Nombre Completo</label>
                                <input type="text" name="NombreCompleto" placeholder="Su nombre completo..." class="sga-soft-input" required>
                            </fieldset>
                        </div>
                        <div class="col-lg-6">
                            <fieldset>
                                <label>Email</label>
                                <input type="email" name="Email" placeholder="Su email..." class="sga-soft-input" required>
                            </fieldset>
                        </div>
                        <div class="col-lg-6">
                            <fieldset>
                                <label>Telefono</label>
                                <input type="text" name="Telefono" placeholder="Su telefono..." class="sga-soft-input" required>
                            </fieldset>
                        </div>
                        <div class="col-lg-6">
                            <fieldset>
                                <label>Fecha de Visita</label>
                                <input type="date" id="sga-cita-fecha" name="FechaCita" class="sga-soft-input" required>
                            </fieldset>
                            <small class="sga-help-text">Lunes a sábado, horarios de 8:00 a 17:00 (cada hora).</small>
                        </div>
                        <div class="col-lg-6">
                            <fieldset>
                                <label>Hora de Visita</label>
                                <select id="sga-cita-hora" name="HoraCita" class="sga-soft-input" required></select>
                            </fieldset>
                        </div>
                        <div class="col-lg-12">
                            <fieldset>
                                <label>Propiedad de Interes</label>
                                <input type="hidden" id="sga-cita-id-propiedad" name="IdPropiedadCita" value="@(Model.IdPropiedadParaCita?.ToString() ?? "")" />
                                <input type="text" id="sga-cita-propiedad" name="PropiedadInteres" value="@propiedadSeleccionada" placeholder="Ejemplo: Casa Familiar - Barrio Los Yoses" class="sga-soft-input" required>
                            </fieldset>
                        </div>
                        <div class="col-lg-12">
                            <fieldset>
                                <label>Mensaje</label>
                                <textarea name="Mensaje" placeholder="Comentarios adicionales..." class="sga-soft-textarea"></textarea>
                            </fieldset>
                        </div>
                        <div class="col-lg-12">
                            <fieldset>
                                <button type="submit" class="orange-button sga-btn-pill">Agendar Cita</button>
                            </fieldset>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/sga-citas.js" asp-append-version="true"></script>
}
